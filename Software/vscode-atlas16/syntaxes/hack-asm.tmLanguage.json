{
  "name": "Hack+ Assembly",
  "scopeName": "source.hack-asm",
  "fileTypes": ["asm"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#label" },
    { "include": "#a-instruction-symbol" },
    { "include": "#a-instruction-number" },
    { "include": "#c-instruction" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.double-slash.hack-asm",
      "match": "//.*$"
    },
    "label": {
      "name": "entity.name.function.hack-asm",
      "match": "^\\s*\\(([A-Za-z_.$:][A-Za-z0-9_.$:]*)\\)",
      "captures": {
        "1": { "name": "entity.name.function.hack-asm" }
      }
    },
    "a-instruction-number": {
      "name": "constant.numeric.hack-asm",
      "match": "^\\s*@[0-9]+"
    },
    "a-instruction-symbol": {
      "patterns": [
        {
          "comment": "Atlas 16 MMIO-Symbole",
          "name": "support.variable.atlas16",
          "match": "^\\s*@(VGA_MODE|VGA_FB_BASE_LO|VGA_FB_BASE_HI|PALETTE_[0-9]+|SPRITE_\\w+|BLIT_\\w+|SQ[0-9]_\\w+|PCM[0-9]_\\w+|MIDI_\\w+|UART_\\w+|RTC_\\w+|TMR_\\w+|BANK_CTRL|MOUSE_\\w+|PAD_\\w+)\\b"
        },
        {
          "comment": "N2T Standard-Symbole",
          "name": "variable.language.hack-asm",
          "match": "^\\s*@(R([0-9]|1[0-5])|SP|LCL|ARG|THIS|THAT|SCREEN|KBD)\\b"
        },
        {
          "comment": "Benutzersymbole und Labels",
          "name": "variable.other.hack-asm",
          "match": "^\\s*@[A-Za-z_.$:][A-Za-z0-9_.$:]*"
        }
      ]
    },
    "c-instruction": {
      "patterns": [
        {
          "comment": "dest=comp;jump",
          "match": "^\\s*(?:([AMD]{1,3})=)?([^;\\s/]+)(?:;(JGT|JEQ|JGE|JLT|JNE|JLE|JMP))?",
          "captures": {
            "1": { "name": "storage.modifier.dest.hack-asm" },
            "2": { "name": "keyword.operator.comp.hack-asm" },
            "3": { "name": "keyword.control.jump.hack-asm" }
          }
        }
      ]
    }
  }
}
